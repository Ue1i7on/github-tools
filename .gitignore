.gitignore
# Environment files
.env
.env.local
.env.*

# Logs and temporary files
*.log
*.tmp
*.swp

# Editor/IDE files
.vscode/
.idea/

# Dependencies and build artifacts
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.dylib
*.dll
*.exe
*.out

# Build directories
dist/
build/
target/
coverage/
htmlcov/
.mypy_cache/
.pytest_cache/
.coverage

# System files
.DS_Store
Thumbs.db